{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:demo",
  "outputDirectory": "dist/frontsmith-demo",
  "functions": {
    "api/contact.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "frontsmith.vercel.app"
        }
      ],
      "destination": "https://frontsmith.neurapath.ai/:path*",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
